  "buhlmann_credibility": {
    "source": "CAS Exam 5 / Bühlmann (1967)",
    "description": "Limited fluctuation credibility - classic formula",
    "formula": "Z = min(1, sqrt(n/k)) where k = (z_p / r)^2 * (CV)^2",
    "test_values": {
      "example_1": {
        "description": "1082 claims needed for full credibility at 90% confidence, 5% accuracy",
        "probability": 0.90,
        "accuracy": 0.05,
        "cv": 1.0,
        "full_cred_standard": 1082,
        "tolerance": 10,
        "note": "k = (1.645 / 0.05)^2 = 1082"
      },
      "example_2": {
        "description": "Partial credibility with 500 claims",
        "claims": 500,
        "full_cred_standard": 1082,
        "expected_z": 0.68,
        "tolerance": 0.02,
        "formula": "Z = sqrt(500/1082) = 0.68"
      }
    }
  },
  "buhlmann_straub": {
    "source": "Bühlmann & Straub (1970)",
    "description": "Bühlmann-Straub model with varying exposure weights",
    "formula": "Z = n / (n + k) where k = s^2 / a (process variance / between-group variance)",
    "test_values": {
      "example_1": {
        "description": "Single risk with 5 years experience",
        "years": 5,
        "k": 10,
        "expected_z": 0.333,
        "tolerance": 0.01,
        "formula": "Z = 5 / (5 + 10) = 0.333"
      },
      "example_2": {
        "description": "Single risk with 20 years experience",
        "years": 20,
        "k": 10,
        "expected_z": 0.667,
        "tolerance": 0.01,
        "formula": "Z = 20 / (20 + 10) = 0.667"
      }
    }
  },
  "poisson_gamma_credibility": {
    "source": "Actuarial literature",
    "description": "Bayesian credibility with Poisson-Gamma model",
    "formula": "Z = n / (n + alpha) where alpha is Gamma shape parameter",
    "test_values": {
      "example_1": {
        "description": "Prior Gamma(2, 0.1), 10 observed claims",
        "prior_alpha": 2,
        "prior_beta": 0.1,
        "observed_claims": 10,
        "exposure": 1,
        "expected_z": 0.833,
        "tolerance": 0.01,
        "formula": "Z = 10 / (10 + 2) = 0.833"
      }
    }
  },
  "experience_rating": {
    "source": "NCCI Experience Rating Plan",
    "description": "Workers compensation experience modification",
    "formula": "Mod = (Actual Primary + w*Actual Excess + (1-w)*Expected Excess) / Expected Total",
    "test_values": {
      "example_1": {
        "description": "Standard experience mod calculation",
        "expected_losses": 100000,
        "actual_losses": 120000,
        "credibility": 0.50,
        "expected_mod": 1.10,
        "tolerance": 0.02,
        "formula": "Mod = 1 + Z*(A-E)/E = 1 + 0.5*(120000-100000)/100000 = 1.10"
      }
    },
    "split_plan": {
      "description": "Primary/Excess split for large deductible credits",
      "split_point": 5000,
      "note": "Claims under split point have higher credibility"
    }
  },
