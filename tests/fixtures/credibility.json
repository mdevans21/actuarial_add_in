  "k_parameter_estimation": {
    "source": "CAS Exam 5",
    "description": "Methods for estimating Bühlmann k parameter",
    "methods": [
      {
        "name": "Empirical Bayes",
        "formula": "k = (Expected Process Variance) / (Variance of Hypothetical Means)",
        "note": "VHM must be unbiased estimator"
      },
      {
        "name": "Method of Moments",
        "formula": "k = s^2 / a where s^2 = within-group variance, a = between-group variance",
        "note": "Requires pooled variance estimation"
      }
