      "d_05": {"d": 0.5, "expected": 0.5960, "tolerance": 0.01},
      "d_06": {"d": 0.6, "expected": 0.6860, "tolerance": 0.01},
      "d_07": {"d": 0.7, "expected": 0.7705, "tolerance": 0.01},
      "d_08": {"d": 0.8, "expected": 0.8507, "tolerance": 0.01},
      "d_09": {"d": 0.9, "expected": 0.9273, "tolerance": 0.01},
